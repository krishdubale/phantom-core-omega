<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0D1117"
    android:padding="24dp">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡ PHANTOM CORE"
        android:textColor="#FF00FF88"
        android:textSize="28sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Remote Compute Offloading Engine"
        android:textColor="#FF58A6FF"
        android:textSize="14sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"/>

    <!-- IP Address Input -->
    <TextView
        android:id="@+id/tv_ip_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="PC DAEMON ADDRESS"
        android:textColor="#FF8B949E"
        android:textSize="12sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="40dp"/>

    <EditText
        android:id="@+id/et_ip_address"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:hint="192.168.1.100"
        android:textColor="#FFFFFFFF"
        android:textColorHint="#FF484F58"
        android:textSize="18sp"
        android:fontFamily="monospace"
        android:background="#FF161B22"
        android:padding="12dp"
        android:inputType="text"
        android:singleLine="true"
        app:layout_constraintTop_toBottomOf="@id/tv_ip_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- TETHER Button -->
    <Button
        android:id="@+id/btn_tether"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:text="⚡ TETHER"
        android:textColor="#FF000000"
        android:textSize="20sp"
        android:textStyle="bold"
        android:background="@android:drawable/btn_default"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/et_ip_address"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp"/>

    <!-- Status -->
    <TextView
        android:id="@+id/tv_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚫ DISCONNECTED"
        android:textColor="#FF8B949E"
        android:textSize="16sp"
        android:fontFamily="monospace"
        app:layout_constraintTop_toBottomOf="@id/btn_tether"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- Stats Panel -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#FF161B22"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/tv_status"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp">

        <TextView
            android:id="@+id/tv_latency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Latency: —"
            android:textColor="#FF00FF88"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_throughput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Throughput: —"
            android:textColor="#FF58A6FF"
            android:textSize="16sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tv_packets"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Packets: —"
            android:textColor="#FFFF7B72"
            android:textSize="16sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
